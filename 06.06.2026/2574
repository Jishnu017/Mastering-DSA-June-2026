//2574. Left and Right Sum Differences

class Solution {
    public int[] leftRightDifference(int[] nums) {
        int left= 0, right= 0, n = nums.length;
        for(int num : nums) right+= num;
        for(int i = 0; i < n; i++) {
            int val = nums[i];
            right-= val;
            nums[i] = Math.abs(left-right);
            left+= val;
        }
        return nums;     
    }
}